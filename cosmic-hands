</div>

<!-- FLASH EFFECT -->
<div id="flash"></div>

<!-- MAIN APP -->
<div id="app">
  <canvas id="canvas3d"></canvas>

  <!-- TOP BAR -->
  <div id="topbar">
    <div id="logo"><strong>COSMIC</strong> HANDS</div>
    <div class="topbar-right">
      <div id="status-label">TRACKING ACTIVE</div>
