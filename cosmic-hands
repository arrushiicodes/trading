<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>COSMIC HANDS — Gesture Universe</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Rajdhani:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --cyan:#00f5ff;
  --purple:#7b2fff;
  --gold:#ffd700;
  --red:#ff3d3d;
  --bg:#00000a;
}

body{
  background:var(--bg);
  overflow:hidden;
  font-family:'Rajdhani',sans-serif;
  color:#fff;
  user-select:none;
}

/* ── PERMISSION GATE ── */
#gate{
  position:fixed;inset:0;z-index:1000;
  background:radial-gradient(ellipse at 50% 40%, #0a0020 0%, #000008 60%, #000 100%);
  display:flex;align-items:center;justify-content:center;
  transition:opacity 0.8s ease;
}
#gate.fade-out{opacity:0;pointer-events:none}

.gate-card{
  width:min(520px,92vw);
  border:1px solid rgba(255,255,255,0.08);
  border-radius:24px;
  background:rgba(255,255,255,0.03);
  backdrop-filter:blur(40px);
  padding:48px 40px 40px;
  text-align:center;
  position:relative;
  overflow:hidden;
}
.gate-card::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(0,245,255,0.04),transparent 50%,rgba(123,47,255,0.04));
  pointer-events:none;
}
.gate-glow{
  width:200px;height:200px;
  margin:0 auto 32px;
  position:relative;
}
.gate-glow canvas{width:100%;height:100%;border-radius:50%}
.hand-icon{
  font-size:72px;
  animation:float 3s ease-in-out infinite;
  display:block;line-height:1;
  filter:drop-shadow(0 0 20px rgba(0,245,255,0.5));
}
@keyframes float{0%,100%{transform:translateY(0) rotate(-5deg)}50%{transform:translateY(-12px) rotate(5deg)}}

.gate-title{
  font-family:'Space Mono',monospace;
  font-size:clamp(20px,4vw,28px);
  font-weight:700;
  letter-spacing:0.1em;
  background:linear-gradient(135deg,#fff 30%,var(--cyan));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  margin-bottom:8px;
}
.gate-sub{
  font-size:13px;letter-spacing:0.15em;color:rgba(255,255,255,0.35);
  text-transform:uppercase;margin-bottom:28px;
}
.gate-desc{
  font-size:15px;line-height:1.7;color:rgba(255,255,255,0.55);
  margin-bottom:36px;
}

/* gesture preview strip */
.gesture-strip{
  display:flex;gap:10px;justify-content:center;flex-wrap:wrap;
  margin-bottom:36px;
}
.gs-chip{
  background:rgba(255,255,255,0.05);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:100px;
  padding:6px 14px;
  font-size:12px;
  letter-spacing:0.08em;
  color:rgba(255,255,255,0.5);
  display:flex;align-items:center;gap:6px;
}
.gs-chip span{font-size:16px}

#allow-btn{
  width:100%;padding:16px;
  background:linear-gradient(135deg,var(--cyan),var(--purple));
  border:none;border-radius:12px;
  font-family:'Rajdhani',sans-serif;
  font-size:17px;font-weight:700;letter-spacing:0.15em;
  color:#000;cursor:pointer;
  text-transform:uppercase;
  transition:transform 0.2s,box-shadow 0.2s;
  position:relative;overflow:hidden;
}
#allow-btn::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,0.2),transparent);
  opacity:0;transition:opacity 0.2s;
}
#allow-btn:hover{transform:translateY(-2px);box-shadow:0 8px 40px rgba(0,245,255,0.35)}
#allow-btn:hover::after{opacity:1}
#allow-btn:active{transform:translateY(0)}

.gate-note{
  margin-top:16px;font-size:11px;
  letter-spacing:0.1em;color:rgba(255,255,255,0.2);
}

/* ── ERROR STATE ── */
#error-panel{
  display:none;
  background:rgba(255,61,61,0.08);
  border:1px solid rgba(255,61,61,0.2);
  border-radius:12px;padding:20px;
  margin-top:20px;
  font-size:13px;color:rgba(255,120,120,0.9);
  line-height:1.6;
}

/* ── MAIN APP ── */
#app{
  position:fixed;inset:0;
  opacity:0;pointer-events:none;
  transition:opacity 1s;
}
#app.visible{opacity:1;pointer-events:all}

#canvas3d{position:absolute;inset:0;width:100%;height:100%}

/* ── WEBCAM PIP ── */
#pip-wrap{
  position:fixed;bottom:28px;right:28px;z-index:50;
  display:flex;flex-direction:column;align-items:center;gap:8px;
}
#pip-ring{
  width:148px;height:148px;
  border-radius:16px;
  padding:3px;
  background:conic-gradient(var(--cyan) 0deg, var(--purple) 180deg, var(--cyan) 360deg);
  animation:spin 6s linear infinite;
  box-shadow:0 0 30px rgba(0,245,255,0.2);
  transition:box-shadow 0.4s;
}
#pip-ring.gesture-hold{box-shadow:0 0 50px rgba(0,245,255,0.6),0 0 80px rgba(123,47,255,0.3)}
#pip-inner{
  width:100%;height:100%;
  border-radius:14px;
  overflow:hidden;
  background:#000;
  position:relative;
}
#pip-canvas{
  width:100%;height:100%;
  object-fit:cover;
  transform:scaleX(-1);
  position:absolute;inset:0;
}
#pip-overlay{
  position:absolute;inset:0;border-radius:14px;
  background:radial-gradient(circle at 50% 100%,rgba(0,0,0,0.4) 0%,transparent 60%);
  pointer-events:none;
}
#gesture-progress{
  position:absolute;bottom:0;left:50%;transform:translateX(-50%);
  width:80%;height:2px;background:rgba(255,255,255,0.1);border-radius:2px;overflow:hidden;
  margin-bottom:6px;
}
#gesture-progress-fill{
  height:100%;background:linear-gradient(90deg,var(--cyan),var(--purple));
  width:0%;transition:width 0.05s;
}

#pip-status{
  font-family:'Space Mono',monospace;
  font-size:9px;letter-spacing:0.15em;
  color:rgba(255,255,255,0.4);text-align:center;
  text-transform:uppercase;
}
#pip-gesture{
  font-size:11px;font-weight:700;
  letter-spacing:0.1em;
  color:var(--cyan);
  transition:color 0.3s;
  text-align:center;
  min-height:16px;
}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}

/* ── HUD ── */
#hud{
  position:fixed;bottom:36px;left:50%;transform:translateX(-50%);
  text-align:center;z-index:40;pointer-events:none;
}
#event-gesture{
  font-family:'Space Mono',monospace;
  font-size:10px;letter-spacing:0.25em;
  color:rgba(255,255,255,0.3);
  text-transform:uppercase;
  margin-bottom:6px;
}
#event-title{
  font-family:'Rajdhani',sans-serif;
  font-size:clamp(28px,5vw,48px);
  font-weight:700;
  letter-spacing:0.15em;
  text-transform:uppercase;
  text-shadow:0 0 40px currentColor,0 0 80px currentColor;
  transition:color 0.6s, text-shadow 0.6s, opacity 0.4s;
}

/* ── GESTURE GUIDE ── */
#guide{
  position:fixed;top:50%;left:28px;transform:translateY(-50%);
  z-index:40;
  display:flex;flex-direction:column;gap:6px;
}
.guide-item{
  display:flex;align-items:center;gap:10px;
  background:rgba(0,0,0,0.4);
  border:1px solid rgba(255,255,255,0.06);
  border-left:2px solid transparent;
  border-radius:8px;
  padding:8px 14px 8px 12px;
  transition:border-left-color 0.3s,background 0.3s,transform 0.2s;
  cursor:default;
}
.guide-item.active{
  border-left-color:var(--cyan);
  background:rgba(0,245,255,0.06);
  transform:translateX(4px);
}
.guide-emoji{font-size:18px;width:24px;text-align:center}
.guide-text{
  display:flex;flex-direction:column;
  font-size:11px;
}
.guide-gesture{letter-spacing:0.1em;color:rgba(255,255,255,0.35);text-transform:uppercase}
.guide-event{font-weight:700;letter-spacing:0.08em;color:rgba(255,255,255,0.7);font-size:12px}

/* ── TOP BAR ── */
#topbar{
  position:fixed;top:0;left:0;right:0;
  z-index:40;
  display:flex;align-items:center;justify-content:space-between;
  padding:20px 28px;
  background:linear-gradient(to bottom,rgba(0,0,10,0.8),transparent);
}
#logo{
  font-family:'Space Mono',monospace;
  font-size:13px;letter-spacing:0.25em;
  color:rgba(255,255,255,0.6);
  text-transform:uppercase;
}
#logo strong{color:var(--cyan)}
#status-dot{
  width:8px;height:8px;border-radius:50%;
  background:var(--cyan);
  box-shadow:0 0 10px var(--cyan);
  animation:pulse 2s ease-in-out infinite;
}
#status-label{
  font-family:'Space Mono',monospace;
  font-size:9px;letter-spacing:0.15em;
  color:rgba(255,255,255,0.3);
}
.topbar-right{display:flex;align-items:center;gap:10px}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}

/* ── LOADING SCREEN ── */
#loading{
  position:fixed;inset:0;z-index:500;
  background:var(--bg);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:20px;
  transition:opacity 0.8s;
}
#loading.fade-out{opacity:0;pointer-events:none}
.load-icon{font-size:48px;animation:float 2s ease-in-out infinite}
.load-text{
  font-family:'Space Mono',monospace;
  font-size:12px;letter-spacing:0.3em;
  color:rgba(255,255,255,0.5);
}
.load-bar{width:240px;height:1px;background:rgba(255,255,255,0.1);border-radius:1px;overflow:hidden}
.load-fill{height:100%;background:linear-gradient(90deg,var(--cyan),var(--purple));width:0%;transition:width 0.3s ease}

/* ── TRANSITION FLASH ── */
#flash{
  position:fixed;inset:0;z-index:30;
  pointer-events:none;
  opacity:0;
  background:radial-gradient(circle at 50% 50%,rgba(255,255,255,0.15),transparent 70%);
  transition:opacity 0.1s;
}
#flash.on{opacity:1}
</style>
</head>
<body>

<!-- PERMISSION GATE -->
<div id="gate">
  <div class="gate-card">
    <div class="gate-glow">
      <span class="hand-icon">🖐️</span>
    </div>
    <div class="gate-title">COSMIC HANDS</div>
    <div class="gate-sub">Gesture-Controlled Universe</div>
    <div class="gate-desc">
      Control cosmic phenomena with your bare hands.<br>
      This experience requires your camera to detect gestures in real time.<br>
