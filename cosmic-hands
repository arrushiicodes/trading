  <!-- GESTURE GUIDE -->
  <div id="guide">
    <div class="guide-item" data-event="blackhole"><span class="guide-emoji">✊</span><div class="guide-text"><span class="guide-gesture">Fist</span><span class="guide-event">Black Hole</span></div></div>
    <div class="guide-item" data-event="galaxy"><span class="guide-emoji">🖐</span><div class="guide-text"><span class="guide-gesture">Open Hand</span><span class="guide-event">Galaxy</span></div></div>
    <div class="guide-item" data-event="wormhole"><span class="guide-emoji">✌️</span><div class="guide-text"><span class="guide-gesture">Peace / V</span><span class="guide-event">Wormhole</span></div></div>
    <div class="guide-item" data-event="pulsar"><span class="guide-emoji">☝️</span><div class="guide-text"><span class="guide-gesture">Index Point</span><span class="guide-event">Pulsar</span></div></div>
    <div class="guide-item" data-event="supernova"><span class="guide-emoji">👍</span><div class="guide-text"><span class="guide-gesture">Thumb Up</span><span class="guide-event">Supernova</span></div></div>
    <div class="guide-item" data-event="quasar"><span class="guide-emoji">🤏</span><div class="guide-text"><span class="guide-gesture">Pinch</span><span class="guide-event">Quasar</span></div></div>
